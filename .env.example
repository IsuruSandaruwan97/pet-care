# Copy this file to .env and fill in the values.
# Never commit .env - it is listed in .gitignore.

# Public production URL used for SEO metadata, sitemap, and structured data
NEXT_PUBLIC_SITE_URL="https://your-domain.com"

# Google Maps Embed URL (include your API key here)
NEXT_PUBLIC_MAP_URL="https://www.google.com/maps/embed/v1/place?key=YOUR_API_KEY&q=YOUR_ADDRESS&maptype=roadmap&zoom=14"

# Set to "true" to enable the right-click / DevTools shortcut guard
NEXT_PUBLIC_RIGHT_CLICK_GUARD="false"

# Optional endpoint for appointment submissions.
# Leave blank for demo mode, or use a Formspree/Zapier/Make/custom webhook URL.
APPOINTMENT_WEBHOOK_URL=""
